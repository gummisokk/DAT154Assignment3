<Window x:Class="Assignment_3.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Assignment_3"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="43*"/>
            <ColumnDefinition Width="357*"/>
        </Grid.ColumnDefinitions>
        <ListView Name="studentList" ItemsSource="{Binding}" Margin="0,70,0,10" Grid.ColumnSpan="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="100" Header="Student" DisplayMemberBinding="{Binding Path=Studentname}"/>
                    <GridViewColumn Width="100" Header="ID" DisplayMemberBinding="{Binding Path=Id}"/>
                    <GridViewColumn Width="100" Header="Alder" DisplayMemberBinding="{Binding Path=Studentage}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <ListView Visibility="Hidden" Name="gradeList" ItemsSource="{Binding}" Margin="0,70,0,10" Grid.ColumnSpan="2">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="100" Header="Student" DisplayMemberBinding="{Binding Path=Student.Studentname}"/>
                    <GridViewColumn Width="100" Header="ID" DisplayMemberBinding="{Binding Path=Student.Id}"/>
                    <GridViewColumn Width="100" Header="Alder" DisplayMemberBinding="{Binding Path=Student.Studentage}"/>
                    <GridViewColumn Width="100" Header="Kurs" DisplayMemberBinding="{Binding Path=CoursecodeNavigation}"/>
                    <GridViewColumn Width="100" Header="Karakter" DisplayMemberBinding="{Binding Path=Grade1}"/>
                </GridView>
            </ListView.View>
        </ListView>
        <Label Content="Søk:" HorizontalAlignment="Left" Margin="10,17,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="10,43,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="263" Height="22" TextChanged="TextBox_SearchName" Grid.ColumnSpan="2"/>

        <Label Content="Kurs" HorizontalAlignment="Left" Margin="187,17,0,0" VerticalAlignment="Top" Grid.Column="1"/>
        <ComboBox Name="inCourse" ItemsSource="{Binding}" HorizontalAlignment="Left" Margin="187,43,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="ComboBox_SearchCourse" Grid.Column="1" IsEditable="True"/>

        <Label Content="Karakter bedre eller lik" HorizontalAlignment="Left" Margin="307,17,0,0" VerticalAlignment="Top" Grid.Column="1"/>
        <ComboBox  Name="inGrade" ItemsSource="{Binding}" HorizontalAlignment="Left" Margin="307,43,0,0" VerticalAlignment="Top" Width="120" SelectionChanged="ComboBox_SearchGrade" Grid.Column="1" IsEditable="True"/>
        
        <Label Grid.Column="1" Content="Stryk" HorizontalAlignment="Left" Margin="441,17,0,0" VerticalAlignment="Top"/>
        <CheckBox Grid.Column="1" Margin="452,43,176,-43" Checked="CheckBox_Stryk" />
    </Grid>
</Window>
